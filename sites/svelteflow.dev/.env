# Sets the style of the site (react|svelte|vue)
NEXT_PUBLIC_FRAMEWORK=svelte

# Algolia configuration
NEXT_PUBLIC_ALGOLIA_ID=LYE7F53FED
NEXT_PUBLIC_ALGOLIA_API_KEY=3ce027beb12a1c3074d560c97512f3cd
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=svelteflow

# URL where our examples are hosted, used for iframe and code on the example pages
NEXT_PUBLIC_EXAMPLES_URL=http://localhost:5173

# URL where the pro examples are hosted, used for iframes and listing of the pro examples
NEXT_PUBLIC_PRO_EXAMPLES_URL=https://pro-example-apps-git-staging-xyflow.vercel.app

# Nhost configuration for auth
NEXT_PUBLIC_NHOST_SUBDOMAIN=local
NEXT_PUBLIC_NHOST_REGION=local

# Turnstile site key for sign up forms (https://docs.nhost.io/products/auth/bot-protection/)
NEXT_PUBLIC_TURNSTILE_SITE_KEY="3x00000000000000000000FF"

# https://vercel.com/docs/builds/configure-a-build#corepack
ENABLE_EXPERIMENTAL_COREPACK=1
